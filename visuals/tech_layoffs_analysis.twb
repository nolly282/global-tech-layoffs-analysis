      <aliases enabled='yes' />
      <column caption='Month Name' datatype='string' name='[Calculation_0247980446511104]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, DATEPARSE(&apos;yyyy-MM&apos;, [year_month]))' />
      </column>
      <column caption='Region Group' datatype='string' name='[Calculation_0247980455550977]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] = &apos;USA&apos; THEN &apos;USA&apos; ELSE &apos;Non-USA&apos; END' />
      </column>
